# FalkorDB connection
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=

# Graph name
GRAPH_NAME=r7

# Field mapping — adapt to your graph's schema
# NAME_PROP=name         # property used as node label
# DESC_PROP=description  # property used for node description
# GROUP_PROP=channel     # property used for color grouping
# GROUP_FALLBACK_PROP=   # fallback grouping property (used when GROUP_PROP is absent)
# NODE_LABEL=            # graph label to query (empty = all labels)

# Server port
PORT=3333
