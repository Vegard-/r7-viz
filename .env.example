# FalkorDB connection
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=

# Graph name
GRAPH_NAME=r7

# Field mapping — adapt to your graph's schema
# NAME_PROP=name         # property used as node label
# DESC_PROP=description  # property used for node description
# NODE_LABEL=            # graph label to query (empty = all labels)

# Multi-level grouping — comma-separated list of properties
# First property = primary group (sets color hue)
# Subsequent properties = sub-groups (varies shade within hue)
# Examples:
#   GROUP_PROPS=channel           # single-level (r7 default)
#   GROUP_PROPS=channel,prefix    # two-level: channel as hue, prefix as shade
#   GROUP_PROPS=label,type        # two-level: label as hue, type as shade (recall)
# Legacy: GROUP_PROP=channel also works (single-level only)
# GROUP_PROPS=channel

# Server port
PORT=3333
